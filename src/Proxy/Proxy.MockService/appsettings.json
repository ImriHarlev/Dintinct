{
  "RabbitMq": {
    "AmqpUri": "amqp://guest:guest@localhost:5672"
  },
  "ProxyMock": {
    "ProxyExchange": "proxy.events",
    "RoutingKey": "file.arrived",
    "Inboxes": [
      {
        "InboxPath": "/network-a/outbox/data",
        "OutboxPath": "/network-b/inbox/data",
        "FilePattern": "*.*"
      },
      {
        "InboxPath": "/network-a/outbox/manifest",
        "OutboxPath": "/network-b/inbox/manifest",
        "FilePattern": "*.json"
      }
    ],
    "Latency": {
      "MinMs": 0,
      "MaxMs": 0
    },
    "Simulation": {
      "ErrorRatePercent": 0,
      "UnsupportedExtensions": []
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
